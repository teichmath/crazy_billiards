package edu.rice.comp504.model.strategy.interactStrategy;

import edu.rice.comp504.model.paint.Ball;

import java.lang.reflect.Array;
import java.util.Arrays;
import java.util.LinkedList;

/**
 * The Composite Strategy uses the Composite Design Pattern to update the ball.   As a result, it calls
 * the interact method on each child
 */
public class CompositeInteractStrategy implements IInteractStrategy {
    private LinkedList<IInteractStrategy> children;

    /**
     * Constructor
     */
    public CompositeInteractStrategy(LinkedList<IInteractStrategy> children) {
        this.children = children;
    }

    /**
     * Get a string of all strategy names in the composite
     * @return String that includes all the names
     */
    public String getName() {
        String name_string =  "composite_interact ";
        for(IInteractStrategy element : children) name_string += element.getName() + " ";
        return name_string;
    }

    /**
     * retrieve a child strategy of a given name
     * @param strname
     * @return the requested strategy
     */
    public IInteractStrategy getBaseStrategy(String strname) {
        IInteractStrategy send_this = null;
        for(IInteractStrategy element: children) {
            if(element.getName().equals(strname)) send_this = element;
        }
        System.out.println("send this: "+send_this.getName());
        return send_this;
    }

    /**
     * perform all interactions using child strategies.
     * @param src  The src ball will impose the interaction strategy on the dest ball.
     * @param dest The dest ball behavior will be affected by the src ball interaction strategy
     */
    public void interact(Ball src, Ball dest) {
        String[] strat_order = new String[]{"billiard", "swapper", "smasher", "nullifier", "blob", "leader", "splitter"};
        for(int i = 0; i < strat_order.length; i++) {
            for(IInteractStrategy element: children) {
                if(element.getName().equals(strat_order[i])) {
                    System.out.println(strat_order[i]);
                    element.interact(src, dest);
                }
            }
        }
    }
}
